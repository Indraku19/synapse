# Synapse backend — copy to .env and fill in values
# Leave USE_ZG_* as false to run fully in local-mock mode.

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# ── ML / Embeddings ───────────────────────────────────────────────────────────
# Model name from sentence-transformers (downloaded on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store backend: "faiss" | "chroma"
VECTOR_STORE=faiss

# ── 0G Storage ────────────────────────────────────────────────────────────────
# Set USE_ZG_STORAGE=true and provide the node endpoint to enable real uploads.
# When false, a deterministic mock CID (zg:<sha256>) is generated locally.
USE_ZG_STORAGE=false
ZG_STORAGE_ENDPOINT=https://indexer-storage-testnet-turbo.0g.ai

# ── 0G Chain ──────────────────────────────────────────────────────────────────
# Set USE_ZG_CHAIN=true and fill in all three fields to enable on-chain writes.
USE_ZG_CHAIN=false
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZG_CHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
ZG_KNOWLEDGE_REGISTRY_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
